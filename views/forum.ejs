<div class="container mt-3">

  <h3 class="text-center mb-3" style="padding-top: 40px ;">Forum</h3>

  <!-- Upper pagination -->
  <nav class="d-flex justify-content-center">
    <ul class="pagination" id="pagination-top"></ul>
  </nav>

  <% if (user) { %>
    <div class="text-center mb-3">
      <a href="/forum/add" class="btn btn-success">Add a post</a>
    </div>
    <% } %>


      <!-- Forum feed -->
      <div id="forum-list" class="mt-3"></div>

      <% if (user) { %>
        <div class="text-center mb-3">
          <a href="/forum/add" class="btn btn-success">Add a post</a>
        </div>
        <% } %>


          <!-- Lower pagination -->
          <nav class="d-flex justify-content-center mt-3">
            <ul class="pagination" id="pagination-bottom"></ul>
          </nav>

</div>

<script src="/js/forum-gallery.js"></script>

<script>
  const currentUser = {
    id: "<%= user?.id %>",
    role: "<%= user?.role %>"
  };
</script>


<script>
  document.addEventListener("DOMContentLoaded", () => {
    const scroll = localStorage.getItem("restoreScroll");
    if (scroll) {
      setTimeout(() => {
        window.scrollTo(0, parseInt(scroll));
      }, 50);
      localStorage.removeItem("restoreScroll");
    }
  });
</script>


<style>
  .forum-item {
    background: #eaefef;
    border-radius: 10px;
    padding: 15px;
    margin-bottom: 15px;
    box-shadow: 0 0 6px rgba(0, 0, 0, 0.08);
  }

  .forum-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .forum-user {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .forum-user img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
  }

  #pagination-bottom {
    margin-bottom: 50px;
  }
</style>