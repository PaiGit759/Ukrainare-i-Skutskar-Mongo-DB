<div class="container mt-4">

  <h3 class="text-center mb-4" style="margin-top: 30px;">Add a post</h3>

  <form action="/forum/add" method="POST" enctype="multipart/form-data">

    <div class="mb-3">
      <label class="form-label">Text a post</label>
      <textarea name="content" class="form-control" rows="5" required></textarea>
    </div>

    <% if (user && user.role==="admin" ) { %>
      <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" name="isPinned" id="isPinned">
        <label class="form-check-label" for="isPinned">
          Output first
        </label>
      </div>
      <% } %>

        <%- include("photo-upload", { currentPhoto: null }) %>

          <button type="submit" class="btn btn-primary" style="margin-bottom: 40px;">Save</button>
          <a href="/forum" class="btn btn-secondary" style="margin-bottom: 40px;">Cancel</a>


  </form>

</div>