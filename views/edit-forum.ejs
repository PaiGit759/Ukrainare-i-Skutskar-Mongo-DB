<div class="container mt-4">

    <h3 class="text-center mb-4" style="margin-top: 30px;">Edit post</h3>

    <form action="/forum/edit" method="POST" enctype="multipart/form-data">

        <input type="hidden" name="id" value="<%= post._id %>">

        <div class="mb-3">
            <label class="form-label">Text a post</label>
            <textarea name="content" class="form-control" rows="5" required><%= post.content %></textarea>
        </div>

        <% if (user && user.role==="admin" ) { %>
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="isPinned" id="isPinned" <%=post.isPinned
                    ? "checked" : "" %>>
                <label class="form-check-label" for="isPinned">
                    Output first
                </label>
            </div>
            <% } %>

                <%- include("photo-upload", { currentPhoto: post.photo }) %>

                    <button type="submit" class="btn btn-primary">Save</button>
                    <a href="/forum" class="btn btn-secondary">Cancel</a>

    </form>

</div>