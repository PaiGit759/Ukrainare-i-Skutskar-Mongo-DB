<div class="container my-5">
  <div class="row justify-content-center">

    <div class="col-12 col-md-10 col-lg-8 col-xl-7">

      <div class="card-body">
        <div class="profile-wrapper text-center" style="background-color: #cfe7ed;">
          <div>

            <form id="register" method="post" action="/register" enctype="multipart/form-data">

              <div class="row">
                <div class="col-md-6 mb-3">
                  <label class="form-label">Username
                    <input type="text" name="name" class="form-control">
                  </label>
                </div>

                <div class="col-md-6 mb-3">
                  <label class="form-label">Email
                    <input type="email" name="email" class="form-control">
                  </label>
                </div>
              </div>

              <div class="row">
                <div class="col-md-6 mb-3">
                  <label class="form-label">First Name
                    <input type="text" name="firstName" class="form-control">
                  </label>
                </div>

                <div class="col-md-6 mb-3">
                  <label class="form-label">Last Name
                    <input type="text" name="lastName" class="form-control">
                  </label>
                </div>
              </div>

              <div class="row">
                <div class="col-md-6 mb-3">
                  <label class="form-label">Birth Date
                    <input type="date" name="birthDate" class="form-control">
                  </label>
                </div>

                <div class="col-md-6 mb-3">
                  <label class="form-label d-block">Gender</label>
                  <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="gender" value="male">
                    <label class="form-check-label">Male</label>
                  </div>
                  <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="gender" value="female">
                    <label class="form-check-label">Female</label>
                  </div>
                </div>
              </div>

              <div class="row">
                <div class="col-md-6 mb-3">
                  <label class="form-label">Place of Birth
                    <input type="text" name="birthPlace" class="form-control">
                  </label>
                </div>

                <div class="col-md-6 mb-3">
                  <label class="form-label">Current Residence
                    <input type="text" name="residence" class="form-control">
                  </label>
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label">About You</label>
                <textarea name="content" rows="6" class="form-control"></textarea>
              </div>

              <div class="mb-3 password-center">
                <label class="form-label">Password</label>
                <div class="input-group password-narrow">
                  <input type="password" name="password" id="password" class="form-control">
                  <button type="button" class="btn btn-outline-secondary" id="togglePassword">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label">Photo</label>
                <div class="d-flex align-items-center gap-2 flex-row flex-wrap">
                  <input type="file" id="foto" name="foto" accept="image/*" class="d-none">
                  <button type="button" class="btn btn-primary" onclick="document.getElementById('foto').click();">
                    Upload Image
                  </button>
                  <input type="text" id="file-name" class="form-control" placeholder="No file chosen" readonly>
                </div>
                <div class="mt-3">
                  <img id="preview-foto" src="" alt="Preview" class="img-fluid rounded"
                    style="max-height:200px; display:none;">
                </div>
              </div>

              <div>
                <input type="submit" value="Submit" class="btn btn-primary">
              </div>
            </form>

            <div>
              <%= message %>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</div>


<script>
  const fileInput = document.getElementById('foto');
  const fileNameDisplay = document.getElementById('file-name');
  const previewImg = document.getElementById('preview-foto');

  fileInput.addEventListener('change', function () {
    if (fileInput.files.length > 0) {
      fileNameDisplay.value = fileInput.files[0].name;

      const reader = new FileReader();
      reader.onload = e => {
        previewImg.src = e.target.result;
        previewImg.style.display = 'block';
      };
      reader.readAsDataURL(fileInput.files[0]);
    } else {
      fileNameDisplay.value = 'No file chosen';
      previewImg.src = '';
      previewImg.style.display = 'none';
    }
  });
</script>

<script>
  const passwordInput = document.getElementById('password');
  const togglePassword = document.getElementById('togglePassword');

  togglePassword.addEventListener('click', () => {
    const isHidden = passwordInput.type === 'password';
    passwordInput.type = isHidden ? 'text' : 'password';

    togglePassword.innerHTML = isHidden
      ? '<i class="bi bi-eye-slash"></i>'
      : '<i class="bi bi-eye"></i>';
  });
</script>



<style>
  .password-narrow {
    max-width: 300px;
  }

  .password-center {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
</style>