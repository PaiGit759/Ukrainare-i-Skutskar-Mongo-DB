<div class="container-fluid py-4">

    <!-- Back button -->
    <div style="padding-top: 20px;">
        <button class="btn btn-secondary mb-4 px-4 py-2" onclick="goBack()">
            ← Back
        </button>
    </div>

    <script>
        function goBack() {
            const data = JSON.parse(localStorage.getItem("returnTo") || "{}");

            if (!data.url || !data.page) {
                window.location.href = "/forum";
                return;
            }

            window.location.href = `${data.url}?page=${data.page}`;
            localStorage.setItem("restoreScroll", data.scroll || 0);
        }

        function openForumUser(userId) {
            const from = location.href;

            localStorage.setItem("returnToProfile", from);

            window.location.href = `/profile?id=${userId}`;
        }


    </script>

    <!-- Main post -->
    <div class="row g-3 mb-4 p-3 border rounded bg-light shadow-sm">

        <!-- Number -->
        <div class="col-1 d-flex align-items-start justify-content-center">
            <span class="badge bg-primary fs-5">0</span>
        </div>

        <!-- Content -->
        <div class="col-8">

            <!-- Name + metadata -->
            <h4 class="mb-2 d-flex flex-wrap align-items-center gap-2">
                <span class="forum-user-link" onclick="openForumUser('<%= post.userId %>')">
                    <%= post.userName %>
                </span>

                <small class="text-muted">
                    — Created: <%= new Date(post.createdAt).toLocaleString() %>
                        | Last reply: <%= new Date(post.lastReplyAt).toLocaleString() %>
                            | Answers: <%= post.replyCount %>
                </small>
            </h4>

            <p class="fs-5">
                <%= post.content %>
            </p>

            <% if (post.photo) { %>
                <img src="<%= post.photo %>" class="rounded mt-3"
                    style="max-width: 300px; width: 100%; height: auto; object-fit: contain;">
                <% } %>
        </div>

        <!-- Photo by the author -->
        <div class="col-3 text-end">
            <img src="<%= post.userFoto %>" class="rounded-circle mb-2"
                style="width: 70px; height: 70px; object-fit: cover; cursor:pointer;"
                onclick="openForumUser('<%= post.userId %>')">
        </div>

    </div>

    <!-- Answers -->
    <h4 class="mb-3">Answers</h4>

    <% replies.forEach((r, index)=> { %>

        <div class="row g-3 mb-3 p-3 border rounded bg-white shadow-sm">

            <!-- Response number -->
            <div class="col-1 d-flex align-items-start justify-content-center">
                <span class="badge bg-secondary fs-6">
                    <%= index + 1 %>
                </span>
            </div>

            <!-- Response content -->
            <div class="col-8">

                <h5 class="mb-1 d-flex flex-wrap align-items-center gap-2">
                    <span class="forum-user-link" onclick="openForumUser('<%= r.userId %>')">
                        <%= r.userName %>
                    </span>

                    <small class="text-muted">
                        — <%= new Date(r.createdAt).toLocaleString() %>
                    </small>
                </h5>

                <p>
                    <%= r.content %>
                </p>

                <% if (r.photo) { %>
                    <img src="<%= r.photo %>" class="rounded mt-2"
                        style="max-width: 250px; width: 100%; height: auto; object-fit: contain;">
                    <% } %>

            </div>

            <!-- Photo by the author of the answer -->
            <div class="col-3 text-end">
                <img src="<%= r.userFoto %>" class="rounded-circle mb-2"
                    style="width: 55px; height: 55px; object-fit: cover; cursor:pointer;"
                    onclick="openForumUser('<%= r.userId %>')">
            </div>

        </div>

        <% }) %>

            <!-- Response form -->
            <% if (user) { %>
                <div class="card p-4 mt-4 shadow-sm">
                    <h5 class="mb-3">Add a reply</h5>

                    <form method="POST" action="/forum/reply" enctype="multipart/form-data">
                        <input type="hidden" name="parentId" value="<%= post.id %>">

                        <textarea name="content" class="form-control mb-3" rows="4" required></textarea>

                        <div class="mb-3">
                            <label class="form-label">Photo (optional)</label>
                            <input type="file" name="photo" class="form-control">
                        </div>

                        <div style="padding-bottom: 20px;">
                            <button class="btn btn-primary px-4 py-2 mt-3">Answer</button>
                        </div>
                    </form>
                </div>
                <% } %>

                    <style>
                        .forum-user-link {
                            cursor: pointer;
                            font-weight: 600;
                            color: #0d6efd;
                        }

                        .forum-user-link:hover {
                            text-decoration: underline;
                        }
                    </style>

                    <script>
                        function openForumUser(userId) {
                            localStorage.setItem("returnToProfile", location.href);
                            window.location.href = `/profile?id=${userId}`;
                        }

                    </script>


</div>